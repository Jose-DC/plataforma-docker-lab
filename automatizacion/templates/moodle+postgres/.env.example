# ----------------------------------------------------------------------
# ARCHIVO .env.example - Plantilla Moodle + PostgreSQL
# Este archivo contiene las variables de entorno utilizadas por el stack.
# ----------------------------------------------------------------------
# .env.example - Plantilla para Moodle + PostgreSQL

# --- Datos generales del proyecto ---
PROJECT=demo_moodle_postgres

# --- Versión de Moodle ---
MOODLE_BRANCH=MOODLE_405_STABLE

# --- Configuración PostgreSQL ---
DB_VERSION=16                # Versión del motor PostgreSQL
POSTGRES_HOST=db             # Nombre del contenedor de PostgreSQL
POSTGRES_DB=moodledb         # Nombre de la base de datos
POSTGRES_USER=moodleuser     # Usuario principal
POSTGRES_PASSWORD=change-me-postgres-user # Contraseña del usuario

# --- Configuración de administrador ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-admin
ADMIN_EMAIL=admin@example.com

# --- pgAdmin (opcional) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change-me-pgadmin
