# ----------------------------------------------------------------------
# ARCHIVO .env.example
# Variables de entorno utilizadas por la plantilla Node.js + PostgreSQL
# Este archivo será reemplazado por .env al crear el proyecto.
# ----------------------------------------------------------------------

# --- Datos generales del proyecto ---
PROJECT=demo_node_postgres

# --- Configuración del lenguaje (opcional, para consistencia del sistema) ---
LANG_VERSION=24      # Versión de Node.js

# --- Configuración de PostgreSQL ---
DB_VERSION=16
POSTGRES_HOST=db
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-postgres-user

# --- Configuración opcional para pgAdmin ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change-me-pgadmin
