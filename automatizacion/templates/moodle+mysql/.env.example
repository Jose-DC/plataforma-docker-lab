# ----------------------------------------------------------------------
# ARCHIVO .env.example - Plantilla Moodle + MySQL
# Este archivo contiene las variables de entorno utilizadas por el stack.
# ----------------------------------------------------------------------
# .env.example - Plantilla para Moodle + MySQL

# --- Datos generales del proyecto ---
PROJECT=demo_moodle_mysql

# --- Versión de Moodle ---
MOODLE_BRANCH=MOODLE_405_STABLE

# --- Configuración MySQL ---
DB_VERSION=8.0                # Versión del motor MySQL
MYSQL_HOST=db                 # Nombre del contenedor de MySQL
MYSQL_DATABASE=moodledb   # Nombre de la base de datos
MYSQL_USER=moodleuser     # Usuario estándar de LimeSurvey
MYSQL_PASSWORD=change-me-mysql-user # Contraseña del usuario estándar
MYSQL_ROOT_PASSWORD=change-me-mysql-root  # Contraseña del usuario root

# --- Configuración de administrador ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-admin
ADMIN_EMAIL=admin@example.com

# --- phpMyAdmin (opcional) ---
PMA_HOST=db                    # Host del servicio MySQL
PMA_USER=${MYSQL_USER}         # Usuario de conexión
PMA_PASSWORD=${MYSQL_PASSWORD} # Contraseña de conexión
