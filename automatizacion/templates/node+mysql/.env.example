# ----------------------------------------------------------------------
# ARCHIVO .env.example
# Variables de entorno para la plantilla Node.js + MySQL
# ----------------------------------------------------------------------

# --- Datos generales del proyecto ---
PROJECT=demo_node_mysql

# --- Configuración de Node.js (opcional) ---
LANG_VERSION=24   # Versión de Node.js (ej: 20, 22, 24)

# --- Configuración de MySQL ---
DB_VERSION=8.0
MYSQL_HOST=db
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=change-me-mysql-user

# --- Configuración opcional para phpMyAdmin ---
PMA_HOST=db
PMA_USER=${MYSQL_USER}
PMA_PASSWORD=${MYSQL_PASSWORD}
