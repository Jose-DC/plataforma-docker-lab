# ----------------------------------------------------------------------
# ARCHIVO .env.example
# Variables para FastApi + MySQL
# Este archivo será reemplazado automáticamente por .env
# ----------------------------------------------------------------------

# --- Datos generales del proyecto ---
PROJECT=demo_fastapi_mysql

# --- Versión de Python ---
LANG_VERSION=3.12

# --- Configuración de MySQL ---
DB_VERSION=8.0
MYSQL_HOST=db
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=change-me-mysql-user

# --- phpMyAdmin opcional ---
PMA_HOST=db
PMA_USER=${MYSQL_USER}
PMA_PASSWORD=${MYSQL_PASSWORD}
