# ----------------------------------------------------------------------
# ARCHIVO .env.example
# Este archivo contiene las variables de entorno utilizadas por el stack.
# Se recomienda copiarlo como ".env" antes de ejecutar Docker Compose.
# ----------------------------------------------------------------------

# --- Datos generales del proyecto ---
PROJECT=demo_php_mysql   # Nombre del proyecto (se usa como prefijo en contenedores, redes, etc.)

# --- Configuración de PHP ---
LANG_VERSION=8.2          # Versión de PHP que se usará en la imagen (ej: 8.2, 8.3)

# --- Configuración de MySQL ---
DB_VERSION=8.0        # Versión del motor MySQL
MYSQL_ROOT_PASSWORD=change-me-mysql-root   # Contraseña del usuario root
MYSQL_DATABASE=appdb           # Nombre de la base de datos principal
MYSQL_USER=appuser             # Usuario estándar para la app
MYSQL_PASSWORD=change-me-mysql-user         # Contraseña del usuario estándar

# --- Configuración opcional para phpMyAdmin ---
PMA_HOST=db              # Host donde está la base de datos (el servicio "db")
PMA_USER=appuser         # Usuario que phpMyAdmin usará para conectarse
PMA_PASSWORD=${MYSQL_PASSWORD}     # Contraseña de ese usuario
