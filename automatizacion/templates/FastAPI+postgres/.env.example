# ----------------------------------------------------------------------
# ARCHIVO .env.example
# Variables para FastAPI (Python) + PostgreSQL
# Este archivo será reemplazado por .env al crear el proyecto.
# ----------------------------------------------------------------------

PROJECT=demo_fastapi_postgres

# Versión de Python (puede ignorarse si el usuario no la pasa)
LANG_VERSION=3.12

# --- PostgreSQL ---
DB_VERSION=16
POSTGRES_HOST=db
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-postgres-user

# --- pgAdmin opcional ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change-me-pgadmin
