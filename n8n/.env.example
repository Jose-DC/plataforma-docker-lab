# N8n Auth (rellenar en .env real)
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=n8n
DB_USER=n8n
DB_PASSWORD=change-me

# Variables internas Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

# URL publica del servicio cuando se expone mediante proxy inverso
WEBHOOK_URL=https://example.com/
